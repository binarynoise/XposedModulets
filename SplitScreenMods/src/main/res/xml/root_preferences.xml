<PreferenceScreen
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    >
    <PreferenceCategory
        app:iconSpaceReserved="false"
        app:title="@string/category_behavior"
        >
        <SwitchPreference
            app:iconSpaceReserved="false"
            app:key="AlwaysAllowMultiInstanceSplit"
            app:summary="@string/alwaysallowmultiinstancesplit_summary"
            app:title="@string/alwaysallowmultiinstancesplit_title"
            />
        <SwitchPreference
            app:iconSpaceReserved="false"
            app:key="KeepSplitScreenRatio"
            app:summary="@string/keepsplitscreenratio_summary"
            app:title="@string/keepsplitscreenratio_title"
            />
    </PreferenceCategory>
    <PreferenceCategory
        app:iconSpaceReserved="false"
        app:title="@string/category_snapping"
        >
        <DropDownPreference
            app:defaultValue="UNCHANGED"
            app:entries="@array/SNAP_MODE_TITLES"
            app:entryValues="@array/SNAP_MODE_KEYS"
            app:iconSpaceReserved="false"
            app:key="SnapMode"
            app:summary="@string/snapmode_summary"
            app:title="@string/snapmode_title"
            app:useSimpleSummaryProvider="true"
            />
        <SwitchPreference
            app:disableDependentsState="true"
            app:iconSpaceReserved="false"
            app:key="FreeSnap"
            app:summary="@string/freesnap_summary"
            app:title="@string/freesnap_title"
            />
        <DropDownPreference
            app:defaultValue="SYSTEM"
            app:entries="@array/SNAP_TARGET_TITLES"
            app:entryValues="@array/SNAP_TARGET_KEYS"
            app:iconSpaceReserved="false"
            app:key="SnapTargets"
            app:title="@string/snaptargets_title"
            app:useSimpleSummaryProvider="true"
            />
        <SeekBarPreference
            android:max="50"
            android:min="0"
            app:defaultValue="33"
            app:iconSpaceReserved="false"
            app:key="CustomRatio"
            app:seekBarIncrement="1"
            app:showSeekBarValue="true"
            app:title="@string/CustomRatio_title"
            />
        <SwitchPreference
            app:defaultValue="true"
            app:iconSpaceReserved="false"
            app:key="CalculateRatios"
            app:summary="@string/CalculateRatios_summary"
            app:title="@string/CalculateRatios_title"
            />
        <SwitchPreference
            app:iconSpaceReserved="false"
            app:key="RemoveMinimalTaskSize"
            app:summary="@string/removeminimaltasksize_summary"
            app:title="@string/removeminimaltasksize_title"
            />
    </PreferenceCategory>
    <Preference
        app:enabled="false"
        app:iconSpaceReserved="false"
        app:selectable="false"
        app:summary="@string/restart_required"
        />
</PreferenceScreen>
